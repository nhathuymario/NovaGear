                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const postRequest = {",
                      "  url: pm.environment.get('baseUrl') + '/api/cart/items',",
                      "  method: 'POST',",
                      "  header: {",
                      "    'Authorization': 'Bearer ' + pm.environment.get('accessToken'),",
                      "    'X-User-Id': pm.environment.get('userId'),",
                      "    'Content-Type': 'application/json'",
                      "  },",
                      "  body: {",
                      "    mode: 'raw',",
                      "    raw: JSON.stringify({",
                      "      productId: parseInt(pm.environment.get('productId') || 1),",
                      "      variantId: 1,",
                      "      productName: 'Test Product',",
                      "      price: 100000,",
                      "      quantity: 2",
                      "    })",
                      "  }",
                      "};",
                      "pm.sendRequest(postRequest, function (err, res) {",
                      "  console.log('Added item before checkout', err || res.code);",
                      "});"
                    ]
                  }
                }
              ],
