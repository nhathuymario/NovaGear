      "item": [
        {
          "name": "5.5.1 Authentication - Đăng ký & Đăng nhập",
          "item": [
            {
              "name": "POST - Đăng ký người dùng mới",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "console.log('[TEST] Register - Response Status:', pm.response.code);",
                      "console.log('[TEST] Register - Response Body:', JSON.stringify(pm.response.json(), null, 2));",
                      "",
                      "pm.test('Register - Status code is 200 or 201', function () {",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                      "});",
                      "",
                      "pm.test('Register - Response contains token', function () {",
                      "    let body = pm.response.json();",
                      "    let token = body.accessToken;",
                      "    pm.expect(token).to.exist;",
                      "    pm.environment.set('accessToken', token);",
                      "});",
                      "",
                      "pm.test('Register - Response contains user info', function () {",
                      "    let body = pm.response.json();",
                      "    pm.expect(body.username).to.exist;",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"testuser_{{$timestamp}}\",\n  \"fullName\": \"Test User\",\n  \"email\": \"testuser_{{$timestamp}}@novagear.com\",\n  \"password\": \"SecurePass@123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/register",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "auth",
                    "register"
                  ]
                }
              }
            },
            {
              "name": "POST - Đăng nhập thành công",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "console.log('[TEST] Login - Response Status:', pm.response.code);",
                      "console.log('[TEST] Login - Response Body:', JSON.stringify(pm.response.json(), null, 2));",
                      "",
                      "pm.test('Login - Status code is 200', function () {",
                      "    pm.expect(pm.response.code).to.equal(200);",
                      "});",
                      "",
                      "pm.test('Login - Response contains accessToken', function () {",
                      "    let body = pm.response.json();",
                      "    let token = body.accessToken;",
                      "    pm.expect(token).to.exist;",
                      "    pm.environment.set('accessToken', token);",
                      "    pm.environment.set('userId', body.userId);",
                      "});",
                      "",
                      "pm.test('Login - Response contains refreshToken', function () {",
                      "    let body = pm.response.json();",
                      "    let token = body.refreshToken;",
                      "    pm.expect(token).to.exist;",
                      "    pm.environment.set('refreshToken', token);",
                      "});"
